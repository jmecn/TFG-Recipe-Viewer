# CI runtime settings. Release-backed tools: leave version empty = latest semver GitHub tag.

JAVA_VERSION=17
NODE_VERSION=24

MC_VERSION=1.20.1
MC_ASSET_INDEX=5
FORGE_BUILD=47.4.13

MODPACK_DIR=Modpack-Modern
MODPACK_REPO=https://github.com/TerraFirmaGreg-Team/Modpack-Modern.git
MODPACK_TAG=

MWE_REPO=jmecn/minecraft-web-export
MWE_VERSION=

SITE_VIEWER_REPO=jmecn/TFG-Recipe-Viewer-React
SITE_VIEWER_VERSION=

RENDERER_REPO=jmecn/emi-recipe-renderer
RENDERER_VERSION=

OPTIMIZE_REPO=jmecn/emi-bundle-optimize
OPTIMIZE_VERSION=

HMC_REPO=3arthqu4ke/headlessmc
HMC_VERSION=

EXPORT_WARMUP_TICKS=100
EXPORT_TIMEOUT_SECONDS=7200

EXPORT_RAW_DIR=export-raw
EXPORT_BUNDLE_SUBDIR=emi
EXPORT_OPT_DIR=export-opt

# CI artifact: export-meta/ + emi-raw-<bundle_id>.tar.gz
EXPORT_ARTIFACT_NAME=tfg-recipe
EXPORT_WORKFLOW_NAME="Export EMI bundle"

SITE_OUTPUT_DIR=site

RUNNER_HOME=/home/runner
