# CI build pins — edit here; workflow_dispatch defaults in build-pages.yml should stay in sync.

JAVA_VERSION=17
NODE_VERSION=20

MC_VERSION=1.20.1
MC_ASSET_INDEX=5
FORGE_BUILD=47.4.13

HMC_VERSION=2.9.0
MODPACK_DIR=Modpack-Modern

MWE_VERSION=v0.2.2
RENDERER_VERSION=0.2.1
OPTIMIZE_REF=master

EXPORT_WARMUP_TICKS=40
EXPORT_TIMEOUT_SECONDS=7200

# Paths relative to repo root (absolute paths are resolved in ci-load-config.sh)
EXPORT_RAW_DIR=export-raw
EXPORT_BUNDLE_SUBDIR=emi
EXPORT_OPT_DIR=export-opt

# GitHub Actions runner home (local runs fall back to $HOME)
RUNNER_HOME=/home/runner
