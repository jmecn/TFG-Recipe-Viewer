# CI build pins — edit here; workflow_dispatch inputs fall back to these values.

JAVA_VERSION=17
NODE_VERSION=20

MC_VERSION=1.20.1
MC_ASSET_INDEX=5
FORGE_BUILD=47.4.13

HMC_VERSION=2.9.0
MODPACK_DIR=Modpack-Modern
# Pin modpack release for bundle id resolution; empty = latest semver tag on Modpack-Modern
MODPACK_TAG=

MWE_VERSION=v0.5.0
RENDERER_VERSION=0.6.0
OPTIMIZE_VERSION=0.4.3

EXPORT_WARMUP_TICKS=100
EXPORT_TIMEOUT_SECONDS=7200

# Paths relative to repo root (absolute paths are resolved in scripts/ci.sh load-config)
EXPORT_RAW_DIR=export-raw
EXPORT_BUNDLE_SUBDIR=emi
EXPORT_OPT_DIR=export-opt

# GitHub Actions runner home (local runs fall back to $HOME)
RUNNER_HOME=/home/runner
